# interviehire-final — AI interview engine (Fastify, port 4000)
# Shared Supabase DB (the SAME instance the backend uses). Ask the project
# owner for the connection string. Prisma tables are already provisioned there.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
PORT=4000

# Candidate web app (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# FastAPI backend base URL — used for self-healing interview sessions. When a
# candidate opens the room with ?sessionId={applicant.id} and the engine has no
# matching session yet, the engine calls
# POST {BACKEND_URL}/api/public/interview-session/{id}/ensure to provision it
# from the applicant's job + rubric (server-to-server, no browser CORS). Leave
# unset to disable self-healing (the link then requires the backend to have
# synced the session beforehand). Local: http://localhost:8002 (or 8000).
# Production (Railway engine var): https://interviehire-backend-production-ca93.up.railway.app
BACKEND_URL=http://localhost:8002

# DeepSeek — powers the Aviral-engine LLM evaluation. WITHOUT a key the engine
# falls back to a deterministic evaluator (the interview still runs and scores).
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_EVALUATION_MAX_TOKENS=12000

# Avatar/interviewer voice transcription — the avatar's voice is captured from
# the interview tab's audio and transcribed server-side (the candidate side uses
# keyless browser STT). Deepgram is webm-native with a large free signup credit.
# Without a provider key, the interviewer side of the transcript is empty (the
# candidate side + report still work). OPENAI_API_KEY is an optional Whisper
# fallback used only when DEEPGRAM_API_KEY is unset.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
OPENAI_API_KEY=
OPENAI_ASR_MODEL=whisper-1

# Optional
# GEMINI_API_KEY=     # AI-authorship fallback
# SMTP_HOST=          # emailed PDF reports
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# REPORT_FROM=
