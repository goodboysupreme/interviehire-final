# interviehire-final — AI interview engine (Fastify, port 4000)
# Shared Supabase DB (the SAME instance the backend uses). Ask the project
# owner for the connection string. Prisma tables are already provisioned there.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
PORT=4000

# Candidate web app (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# DeepSeek — powers the Aviral-engine LLM evaluation. WITHOUT a key the engine
# falls back to a deterministic evaluator (the interview still runs and scores).
DEEPSEEK_API_KEY=
# deepseek-v4-flash = cheapest model ($0.14/M in, $0.28/M out); deepseek-chat/-reasoner
# deprecate 2026-07-24 and already alias to V4 Flash's non-thinking/thinking modes.
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_EVALUATION_MAX_TOKENS=12000

# Optional
# OPENAI_API_KEY=     # Whisper audio transcription (typed answers don't need it)
# GEMINI_API_KEY=     # AI-authorship fallback
# SMTP_HOST=          # emailed PDF reports
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# REPORT_FROM=
