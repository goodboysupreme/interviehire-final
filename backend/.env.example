# ─────────────────────────────────────────────────────
# Shared Supabase database (ask project owner for URL)
# ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres

# App config
SECRET_KEY=change-this-in-production
APP_NAME=Hiring Dashboard

# CORS configuration (recruiter dashboard origin)
FRONTEND_URL=http://localhost:3000

# Candidate interview room (engine web app). The emailed calendar-invite link
# opens this — the same room as "Run test interview". Prod: the root domain URL
# (e.g. https://interviehire.com) if using subroute proxied routing.
INTERVIEW_ROOM_URL=http://localhost:3001

# Email for calendar invites. Gmail SMTP is free: Google Account → Security →
# App passwords → use that as SMTP_PASSWORD. Empty = simulation mode (logs only).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=interviehire@gmail.com

# Cross-site auth cookie (set in production: none / true)
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=false

# API Keys (ask project owner for key)
DEEPSEEK_API_KEY=

# Optional API Keys
# GROQ_API_KEY=
# GROK_API_KEY=
# XAI_API_KEY=
# GEMINI_API_KEY=

# Optional: raises GitHub Search API rate limit (Talent Finder web source) to 5000/hr.
# Works without it at GitHub anonymous rate. Create at github.com/settings/tokens (no scopes needed).
GITHUB_TOKEN=

# Web Search source (Talent Finder, non-tech roles) — free official Brave Search API.
# Get a free key at https://brave.com/search/api (2000 queries/mo). Public results only.
BRAVE_API_KEY=

# Web Search source (Talent Finder, any role) — pick ONE free provider:
#  Google Programmable Search (free 100/day): GOOGLE_CSE_KEY + GOOGLE_CSE_ID (cse.google.com)
#  Self-hosted SearXNG (free, unlimited): SEARXNG_URL=http://localhost:8080  (docker run -d -p 8080:8080 searxng/searxng)
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=
SEARXNG_URL=
